# =============================================================================
# PravaraMES Environment Configuration
# =============================================================================
# Placeholder-only template. Copy this file to .env only for local development.
# NEVER commit .env to version control.
# Production/staging values must come from Enclii secrets backed by
# Lockbox/Vault/ESO, not from copied documentation or chat transcripts.

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Port Allocation (4500-4599 reserved for PravaraMES)
# -----------------------------------------------------------------------------
PRAVARA_API_PORT=4500
PRAVARA_UI_PORT=4501
TELEMETRY_WORKER_PORT=4502

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=replace-with-local-or-secret-store-database-url
DATABASE_MAX_CONNECTIONS=25
DATABASE_MAX_IDLE_CONNECTIONS=5

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Janua SSO (OIDC)
# -----------------------------------------------------------------------------
OIDC_ISSUER=https://auth.madfam.io
OIDC_JWKS_URL=https://auth.madfam.io/.well-known/jwks.json
OIDC_AUDIENCE=pravara-api
# Run: cd <janua>/apps/api && python scripts/seed_core_clients.py
OIDC_CLIENT_ID=replace-with-janua-client-id

# -----------------------------------------------------------------------------
# MQTT (EMQX)
# -----------------------------------------------------------------------------
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_USERNAME=pravara
MQTT_PASSWORD=replace-with-local-mqtt-password
MQTT_CLIENT_ID=pravara-telemetry-worker

# -----------------------------------------------------------------------------
# Cloudflare R2 Storage
# -----------------------------------------------------------------------------
R2_ENDPOINT=replace-with-r2-endpoint
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET=pravara-dev

# -----------------------------------------------------------------------------
# Tezca (Mexican law intelligence)
# -----------------------------------------------------------------------------
TEZCA_ENABLED=false
TEZCA_API_URL=https://tezca.mx/api/v1
TEZCA_API_KEY=replace-with-tezca-api-key
TEZCA_WEBHOOK_SECRET=replace-with-tezca-webhook-secret

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4500
NEXT_PUBLIC_JANUA_URL=https://auth.madfam.io
# Run: cd <janua>/apps/api && python scripts/seed_core_clients.py
NEXT_PUBLIC_JANUA_CLIENT_ID=replace-with-janua-client-id
